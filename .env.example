# ============================================================
#  StockGuru v2.0 — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit your real .env file to git.
# ============================================================

# ── AI / LLM ────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get from: https://aistudio.google.com/app/apikey  (free tier)
GEMINI_API_KEY=your_gemini_api_key_here

# ── TELEGRAM ALERTS ─────────────────────────────────────────
# Create a bot via @BotFather on Telegram, get the token
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your personal Telegram chat ID (get via @userinfobot)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── IIFL BROKER API (optional — for live NSE data) ──────────
# Get from: https://ttweb.indiainfoline.com → My Account → Trading API
IIFL_API_KEY=your_iifl_api_key_here
IIFL_SECRET_KEY=your_iifl_secret_key_here

# ── SECURITY (M1 — Milestone 1) ─────────────────────────────
# Protects write/trigger API endpoints (run-now, update-keys, etc.)
# Leave empty for local dev. SET THIS for Railway production.
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
STOCKGURU_API_KEY=

# ── CORS (M1 — Milestone 1) ─────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave empty for local dev (defaults to localhost).
# For Railway: set to your Railway app URL
# Example: ALLOWED_ORIGINS=https://stockguru-production.up.railway.app
ALLOWED_ORIGINS=

# ── PAPER TRADING ────────────────────────────────────────────
# Initial virtual capital in INR (default: ₹5,00,000)
PAPER_CAPITAL=500000

# ── SERVER ───────────────────────────────────────────────────
FLASK_PORT=5050
PRICE_REFRESH_MINUTES=5
ALERT_CHECK_MINUTES=15

# ── WEBSOCKET (M2) ───────────────────────────────────────────
# No extra env vars needed — Flask-SocketIO auto-detects gevent.
# For Railway: WebSocket is supported natively (no extra proxy config needed).

# ── SHOONYA (Finvasia) BROKER API (NSE/BSE/MCX Live Data) ─────
# Get from: https://prism.finvasia.com/ -> API Manager
SHOONYA_USER=your_client_code
SHOONYA_PASSWORD=your_trading_password
SHOONYA_API_KEY=your_shoonya_api_key
SHOONYA_TOTP_KEY=your_totp_secret_key_base32
# SHOONYA_VENDOR_CODE=            # Optional: defaults to UID_U

# ── PRODUCTION CHECKLIST (Railway M3) ───────────────────────
# 1. Set STOCKGURU_API_KEY  (strong random key — protects write endpoints)
# 2. Set ALLOWED_ORIGINS    (your Railway URL, e.g. https://xxx.up.railway.app)
# 3. Set ANTHROPIC_API_KEY  (required for Claude Intelligence)
# 4. Set GEMINI_API_KEY     (required for Debate Engine + Web Researcher)
# 5. Set TELEGRAM_TOKEN + TELEGRAM_CHAT_ID (for alerts + HITL)
# 6. Set SHOONYA_* variables for live Indian market data
# 7. Leave PORT unset       (Railway auto-injects it)
# 8. Gunicorn worker: GeventWebSocketWorker (configured in gunicorn.conf.py)
